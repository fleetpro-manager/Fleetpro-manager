{
  "name": "fleetpro-transport-manager",
  "private": true,
  "version": "2.6.0",
  "type": "module",
  "main": "dist/server.cjs",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "cap:setup": "npx cap add android && node scripts/update-manifest.js",
    "cap:sync": "npx cap sync && node scripts/update-manifest.js"
  },
  "dependencies": {
    "@capacitor-community/file-opener": "^8.0.1",
    "@capacitor/android": "^8.2.0",
    "@capacitor/app": "^8.1.0",
    "@capacitor/camera": "^8.0.2",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/geolocation": "^8.1.0",
    "@capacitor/share": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@firebase/eslint-plugin-security-rules": "^0.0.2",
    "@google/genai": "^1.46.0",
    "@types/express": "^5.0.6",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "dotenv": "^17.4.2",
    "esbuild": "^0.28.0",
    "express": "^5.2.1",
    "firebase": "^12.13.0",
    "firebase-admin": "^14.0.0",
    "framer-motion": "^12.34.3",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "^0.562.0",
    "motion": "^12.34.3",
    "otpauth": "^9.5.1",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "recharts": "^3.6.0",
    "tsx": "^4.22.4",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "@types/bcryptjs": "^2.4.6",
    "bcryptjs": "^3.0.3"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5"
  }
}
